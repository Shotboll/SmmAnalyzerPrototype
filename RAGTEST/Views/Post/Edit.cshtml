@model PostCreateModel

@{
    ViewData["Title"] = "Редактирование поста";
}

<div class="page-header">
    <h1 class="page-title">Редактирование поста</h1>
    <p class="page-subtitle">
        Измените текст публикации или сообщество. После сохранения предыдущие результаты проверок будут сброшены.
    </p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4">@ViewBag.Error</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="app-card">
            <div class="app-card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()

                    <input asp-for="PostId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CommunityId" class="form-label fw-semibold"></label>
                        <select asp-for="CommunityId"
                                asp-items="@(new SelectList(Model.Communities, "Id", "Name"))"
                                class="form-select">
                            <option value="">Выберите сообщество</option>
                        </select>
                        <span asp-validation-for="CommunityId" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Text" class="form-label fw-semibold"></label>
                        <textarea asp-for="Text"
                                  class="form-control"
                                  rows="14"
                                  maxlength="5000"
                                  placeholder="Введите текст поста"></textarea>
                        <span asp-validation-for="Text" class="text-danger small"></span>
                        <div class="form-text">Максимум 5000 символов.</div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                        <a asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">Назад к посту</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="app-card h-100">
            <div class="app-card-body">
                <h3 class="section-card-title mb-3">Что произойдёт после сохранения</h3>

                <div class="d-flex flex-column gap-3">
                    <div class="info-note">
                        <div class="info-note-title">Пост будет обновлён</div>
                        <div class="info-note-text">Система сохранит новый текст и выбранное сообщество.</div>
                    </div>

                    <div class="info-note">
                        <div class="info-note-title">Результаты проверок сбросятся</div>
                        <div class="info-note-text">
                            Анализы ошибок, стиля и регламентов относятся только к прежней версии текста,
                            поэтому после изменения они удаляются.
                        </div>
                    </div>

                    <div class="info-note">
                        <div class="info-note-title">Понадобится повторная проверка</div>
                        <div class="info-note-text">
                            После сохранения можно снова открыть карточку поста и запустить нужные анализы.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}