@model RAGTEST.Models.RegulationCheckPageModel

@{
    ViewData["Title"] = "Проверка по регламентам";
}

<div class="container reg-page mt-4">
    <h2 class="mb-2">Проверка поста по регламентам</h2>
    <div class="page-subtitle">
        Система проверяет текст по правилам выбранного сообщества и показывает найденные нарушения.
    </div>

    <div class="editor-card">
        <form asp-action="RegulationCheck" method="post" id="regulationForm">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="CommunityId" class="form-label">Сообщество</label>
                <select asp-for="CommunityId" class="form-select" id="communitySelect">
                    <option value="">Выберите сообщество</option>
                    @foreach (var community in Model.Communities)
                    {
                        <option value="@community.Id">@community.Name</option>
                    }
                </select>
                <span asp-validation-for="CommunityId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Text" class="form-label">Текст поста</label>
                <textarea asp-for="Text"
                          class="form-control"
                          id="postText"
                          rows="12"
                          maxlength="5000"
                          placeholder="Введите текст поста для проверки..."></textarea>
                <div class="form-text">
                    <span id="charCounter">0</span> / 5000 символов
                </div>
                <span asp-validation-for="Text" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-primary" id="submitButton">Проверить</button>
                <a asp-action="RegulationCheck" class="btn btn-outline-secondary">Очистить</a>
            </div>
        </form>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mt-4">
            @ViewBag.Error
        </div>
    }

    @if (Model.HasResult)
    {
        <div class="result-card">
            <div class="result-status @(Model.HasViolations ? "bad" : "ok")">
                @(Model.HasViolations ? "Обнаружены нарушения" : "Нарушений не найдено")
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Comment))
            {
                <p class="result-comment">@Model.Comment</p>
            }

            @if (Model.Violations.Any())
            {
                <div class="violations-list">
                    @foreach (var item in Model.Violations)
                    {
                        <div class="violation-item">
                            <div class="violation-row">
                                <div>
                                    <div class="rule-chip">Правило @item.RuleNumber</div>
                                </div>

                                <div class="violation-content">
                                    <h5 class="violation-title">Нарушение регламента</h5>

                                    <div class="field-group">
                                        <div class="field-label">Фрагмент поста</div>
                                        <div class="field-text">
                                            <span class="matched-inline">
                                                @(string.IsNullOrWhiteSpace(item.MatchedText) ? "Не указан" : item.MatchedText)
                                            </span>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(item.Explanation))
                                    {
                                        <div class="field-group">
                                            <div class="field-label">Причина</div>
                                            <p class="field-text">@item.Explanation</p>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.RuleShort))
                                    {
                                        <div class="field-group">
                                            <div class="field-label">Основание</div>
                                            <p class="field-text rule-text">@item.RuleShort</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            Результаты проверки появятся здесь после отправки текста.
        </div>
    }
</div>

<div id="loadingOverlay" class="loading-overlay d-none">
    <div class="loading-modal">
        <div class="spinner-border text-primary loading-spinner" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>

        <h4 class="mt-3 mb-2">Идёт проверка по регламентам</h4>
        <p class="text-muted mb-2" id="loadingMessage">
            Выполняется анализ текста и поиск нарушений...
        </p>
        <small class="text-secondary">
            Проверка может занять некоторое время.
        </small>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const form = document.getElementById('regulationForm');
            const submitBtn = document.getElementById('submitBtn');
            const loadingOverlay = document.getElementById('loadingOverlay');
            const loadingMessage = document.getElementById('loadingMessage');
            const postText = document.getElementById('postText');
            const communitySelect = document.getElementById('communitySelect');
            const charCounter = document.getElementById('charCounter');

            const loadingMessages = [
                'Выполняется анализ текста и поиск нарушений...',
                'Извлекаются подходящие регламенты сообщества...',
                'Сравниваем текст поста с найденными правилами...',
                'Формируем итоговый результат проверки...',
                'Почти готово...'
            ];

            let loadingInterval = null;

            function updateCharCounter() {
                charCounter.textContent = postText.value.length.toString();
            }

            function startLoadingMessages() {
                let index = 0;
                loadingMessage.textContent = loadingMessages[index];

                loadingInterval = setInterval(() => {
                    index++;
                    if (index < loadingMessages.length) {
                        loadingMessage.textContent = loadingMessages[index];
                    }
                }, 7000);
            }

            function stopLoadingMessages() {
                if (loadingInterval) {
                    clearInterval(loadingInterval);
                    loadingInterval = null;
                }
            }

            function showLoading() {
                loadingOverlay.classList.remove('d-none');
                document.body.classList.add('loading-active');

                submitBtn.disabled = true;
                submitBtn.textContent = 'Проверка...';

                startLoadingMessages();
            }

            function hideLoading() {
                loadingOverlay.classList.add('d-none');
                document.body.classList.remove('loading-active');

                submitBtn.disabled = false;
                submitBtn.textContent = 'Проверить';

                stopLoadingMessages();
            }

            updateCharCounter();
            postText.addEventListener('input', updateCharCounter);

            form.addEventListener('submit', function () {
                const text = postText.value.trim();
                const communityId = communitySelect.value;

                if (!communityId || !text) {
                    hideLoading();
                    return;
                }

                showLoading();
            });

            window.addEventListener('pageshow', function () {
                hideLoading();
            });
        })();
    </script>
}