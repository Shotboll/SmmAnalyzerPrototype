<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RAGTEST</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RAGTEST.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg app-navbar">
            <div class="container">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="brand-mark">SA</span>
                    <span>SmmAnalyzer</span>
                </a>

                <button class="navbar-toggler app-navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto app-nav-list">
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Community" asp-action="Index">Сообщества</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-area="" asp-controller="Regulation" asp-action="Index">Регламенты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link app-nav-link" asp-controller="Post" asp-action="Index">Посты</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <div class="container">
            <main role="main" class="app-main">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="app-footer">
        <div class="container">
            <div class="app-footer-inner">
                <span>&copy; 2026 - RAGTEST</span>
                <span class="footer-muted">Система анализа постов для сообществ</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>