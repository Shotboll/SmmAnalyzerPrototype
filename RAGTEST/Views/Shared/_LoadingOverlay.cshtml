@model LoadingOverlayViewModel

<div id="@Model.OverlayId" class="loading-overlay d-none">
    <div class="loading-modal">
        <div class="spinner-border text-primary loading-spinner" role="status">
            <span class="visually-hidden">Загрузка...</span>
        </div>

        <h4 class="mt-3 mb-2">@Model.Title</h4>
        <p class="text-muted mb-2" id="@Model.MessageId">
            @Model.InitialMessage
        </p>
        <small class="text-secondary">
            @Model.Hint
        </small>
    </div>
</div>