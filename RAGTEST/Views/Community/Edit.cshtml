@using SmmAnalyzerPrototype.Data.Models.DTO.Community
@model UpdateCommunityRequest

@{
    ViewData["Title"] = "Редактировать сообщество";
    var id = ViewBag.Id;
}

<div class="page-header">
    <h1 class="page-title">Редактировать сообщество</h1>
    <p class="page-subtitle">Обновите параметры аудитории и стиля общения для выбранного сообщества.</p>
</div>

<div class="app-card">
    <div class="app-card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название</label>
                <input asp-for="Name" class="form-control" placeholder="Введите название сообщества" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TargetAudience" class="form-label">Целевая аудитория</label>
                <input asp-for="TargetAudience" class="form-control" placeholder="Опишите целевую аудиторию" />
                <span asp-validation-for="TargetAudience" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="StyleProfile" class="form-label">Стиль общения</label>
                <input asp-for="StyleProfile" class="form-control" placeholder="Опишите стиль общения" />
                <span asp-validation-for="StyleProfile" class="text-danger small"></span>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>