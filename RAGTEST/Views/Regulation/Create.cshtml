@using SmmAnalyzerPrototype.Data.Models.DTO.Regualtion
@model CreateRegulationRequest

@{
    ViewData["Title"] = "Создать регламент";
}

<div class="page-header">
    <h1 class="page-title">Создать регламент</h1>
    <p class="page-subtitle">Добавьте новый регламент для выбранного сообщества. Он будет использоваться при проверке постов.</p>
</div>

<div class="app-card">
    <div class="app-card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Название</label>
                <input asp-for="Title" class="form-control" placeholder="Например, Политика и общественные темы" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label">Категория</label>
                <input asp-for="Category" class="form-control" placeholder="Например, Политика, Реклама, Тон общения" />
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CommunityId" class="form-label">Сообщество</label>
                <select asp-for="CommunityId" asp-items="@(ViewBag.Communities)" class="form-select">
                    <option value="">-- Выберите сообщество --</option>
                </select>
                <span asp-validation-for="CommunityId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Content" class="form-label">Текст регламента</label>
                <textarea asp-for="Content" class="form-control" rows="10" placeholder="Введите полный текст регламента"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-primary">Создать регламент</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}