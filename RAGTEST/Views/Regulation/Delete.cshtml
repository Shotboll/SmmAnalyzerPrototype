@using SmmAnalyzerPrototype.Data.Models.DTO.Regualtion
@model RegulationDocumentDto

<h2>Удаление регламента</h2>

<h3>Вы уверены, что хотите удалить регламент "@Model.Title"?</h3>

<dl class="row">
    <dt class="col-sm-2">Название</dt>
    <dd class="col-sm-10">@Model.Title</dd>
    <dt class="col-sm-2">Категория</dt>
    <dd class="col-sm-10">@Model.Category</dd>
    <dt class="col-sm-2">Сообщество</dt>
    <dd class="col-sm-10">@Model.CommunityId</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Удалить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>