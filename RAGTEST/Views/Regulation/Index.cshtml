@using SmmAnalyzerPrototype.Data.Models.DTO.Regualtion
@model List<RegulationDocumentDto>

<h2>Регламенты</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Создать регламент</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>Категория</th>
            <th>Сообщество</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Category</td>
                <td>@item.CommunityId</td> @* Здесь можно вывести название сообщества, если нужно *@
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Редактировать</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                </td>
            </tr>
        }
    </tbody>
</table>