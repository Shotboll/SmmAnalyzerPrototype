@{
    ViewData["Title"] = "Проверка стиля";
}

<h1>Проверка стиля текста</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<div class="row">
    <!-- Левая колонка: форма -->
    <div class="col-md-6">
        <form asp-action="StyleCheck" method="post">
            <div class="mb-3">
                <label class="form-label">Целевая аудитория</label>
                <input name="audience" class="form-control" value="@ViewBag.Audience" placeholder="например, студенты 18–25 лет" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Желаемый стиль</label>
                <input name="style" class="form-control" value="@ViewBag.Style" placeholder="например, неформальный, дружелюбный" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Текст поста</label>
                <textarea name="text" class="form-control" rows="10" required>@ViewBag.Text</textarea>
            </div>
            <button type="submit" class="btn btn-primary">Проверить стиль</button>
        </form>
    </div>

    <!-- Правая колонка: результат -->
    <div class="col-md-6">
        <h3>Результат анализа</h3>
        @if (ViewBag.StyleResult != null)
        {
            <div class="border p-3 bg-light" style="white-space: pre-wrap; font-family: monospace;">
                @ViewBag.StyleResult
            </div>
        }
        else
        {
            <p>Пока нет результата. Заполните форму и нажмите "Проверить стиль".</p>
        }
    </div>
</div>