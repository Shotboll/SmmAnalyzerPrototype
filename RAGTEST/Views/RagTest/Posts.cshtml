@using RAGTEST.Models.VkModels
@model List<VkPostDto>

@{
    ViewData["Title"] = "Посты из VK";
}

<h1>Последние посты сообщества</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

@if (!Model.Any())
{
    <p>Нет постов для отображения.</p>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Текст</th>
                <th>Лайки</th>
                <th>Комментарии</th>
                <th>Репосты</th>
                <th>Просмотры</th>
                <th>Ссылка</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model)
            {
                <tr>
                    <td>@post.Date.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (post.Text.Length > 200)
                        {
                            @post.Text.Substring(0, 200)
                
                            <text>...</text>
                        }
                        else
                        {
                            @post.Text
                        }
                    </td>
                    <td>@post.Likes</td>
                    <td>@post.Comments</td>
                    <td>@post.Reposts</td>
                    <td>@post.Views</td>
                    <td>
                        <a href="@($"https://vk.com/wall-{ViewBag.GroupId}_{post.Id}")" target="_blank">Открыть</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}