@{
    ViewData["Title"] = "Тестирование RAG";
}

<h1>Тестирование RAG</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
@if (ViewBag.Success != null)
{
    <div class="alert alert-danger">@ViewBag.Success</div>
}

<div class="row">
    <div class="col-md-6">
        <h3>Проверить текст</h3>
        <form asp-action="CheckText" method="post">
            <div class="md-3">
                <label class="form-label">Текст</label>
                <textarea name="text" class="form-control" rows="10" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">ID сообщества</label>
                <input name="communityId" class="form-control" value="11111111-1111-1111-1111-111111111111" required />
            </div>
            <button type="submit" class="btn btn-primary">Проверить текст</button>
        </form>
    </div>

    <div class="col-md-6">
        <h3>Результат анализа</h3>
        @if (ViewBag.Result != null)
        {
            <div class="border p-3 bg-light" style="white-space: pre-wrap; font-family: monospace;">
                @ViewBag.Result
            </div>
        }
        else
        {
            <p>Пока нет результатов. Отправьте текст для проверки.</p>
        }
    </div>
</div>

<!-- (Опционально) Можно вывести найденные чанки для отладки -->
@if (ViewBag.FoundChunks != null)
{
    <hr />
    <h4>Найденные чанки (для отладки)</h4>
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Текст чанка</th>
                <th>Категория</th>
                <th>Расстояние</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chunk in ViewBag.FoundChunks)
            {
                <tr>
                    <td>@chunk.ChunkText</td>
                    <td>@chunk.MetadataJson</td>
                    <td>@chunk.Distance.ToString("F4")</td>
                </tr>
            }
        </tbody>
    </table>
}