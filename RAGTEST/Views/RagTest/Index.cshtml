@{
    ViewData["Title"] = "Тестирование RAG";
}

<h1>Тестирование RAG</h1>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}
@if (ViewBag.Success != null)
{
    <div class="alert alert-danger">@ViewBag.Success</div>
}

<div class="row">
    <div class="col-md-6">
        <h3>Добавить чанк регламента</h3>
        <form asp-action="AddChunk" method="post">
            <div class="md-3">
                <label class="form-label">Текст чанка</label>
                <textarea name="chunkText" class="form-control" rows="10" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">ID сообщества</label>
                <input name="communityId" class="form-control" value="11111111-1111-1111-1111-111111111111" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Метаданные (JSON)</label>
                <input name="metadata" class="form-control" value='@(ViewBag.Metadata ?? "{\"category\":\"Политика\"}")' />
            </div>
            <button type="submit" class="btn btn-primary">Добавить чанк</button>
        </form>
    </div>

    <div class="col-md-6">
        <h3>Поиск похожих чанков</h3>
        <form asp-action="Search" method="post">
            <div class="mb-3">
                <label class="form-label">Текст запроса</label>
                <textarea name="queryText" class="form-control" rows="10" required>@ViewBag.QueryText</textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">ID сообщества</label>
                <input name="communityId" class="form-control" value="@(ViewBag.CommunityId ?? "11111111-1111-1111-1111-111111111111")" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Количество результатов (topK)</label>
                <input name="topK" class="form-control" value="@(ViewBag.TopK ?? 5)" type="number" min="1" />
            </div>
            <div class="mb-3">
                <label class="form-label">Косинусовое сходство (порог ≤)</label>
                <input name="threshold" class="form-control" type="number" min="0.1" step="0.1" value="@(ViewBag.Threshold?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "0.5")" />
            </div>
            <button type="submit" class="btn btn-success">Искать</button>
        </form>
    </div>
</div>

<!-- Результаты поиска -->
@if (ViewBag.Results != null && ((IEnumerable<dynamic>)ViewBag.Results).Any())
{
    <hr />
    <h3>Результаты поиска по запросу: "@ViewBag.QueryText"</h3>
    <p>Порог косинусного расстояния (≤ @ViewBag.Threshold), показано @ViewBag.TopK ближайших</p>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Текст чанка</th>
                <th>Метаданные</th>
                <th>ID регламента</th>
                <th>Косинусное расстояние</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var chunk in ViewBag.Results)
            {
                var distance = ViewBag.Distances[chunk.Id];
                <tr>
                    <td>@chunk.ChunkText</td>
                    <td>@chunk.MetadataJson</td>
                    <td>@chunk.RegulationId</td>
                    <td>@distance.ToString("F4")</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (ViewBag.Results != null)
{
    <p>Нет результатов, удовлетворяющих порогу.</p>
}