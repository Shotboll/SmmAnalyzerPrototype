@model RAGTEST.Models.GrammarCheckPageModel

@{
    ViewData["Title"] = "Проверка на ошибки";
}

<div class="container py-4">
    <div class="page-header">
        <h1 class="page-title">Проверка поста на ошибки</h1>
        <p class="page-subtitle">
            Проверка выполняется для уже сохранённого поста. Пояснение по каждой ошибке можно запросить отдельно.
        </p>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger mb-4">@ViewBag.Error</div>
    }

    <div class="app-card mb-4">
        <div class="app-card-body">
            <div class="mb-3">
                <div class="text-muted small">Сообщество</div>
                <div class="fw-semibold">@Model.CommunityName</div>
            </div>

            <div class="mb-3">
                <div class="text-muted small mb-2">Текст поста</div>
                <div class="post-content-box">@Model.Text</div>
            </div>

            <form asp-action="Grammar" method="post" id="grammarForm">
                @Html.AntiForgeryToken()
                <input asp-for="PostId" type="hidden" />

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary" id="submitBtn">
                        Проверить
                    </button>

                    <a asp-controller="Post" asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">
                        Назад к посту
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.HasResult)
    {
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="app-card h-100">
                    <div class="app-card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
                            <div>
                                <h3 class="section-card-title mb-1">Подтверждённые ошибки</h3>
                                <p class="section-card-text mb-0">Ошибки, которые прошли фильтрацию и показаны в основном результате.</p>
                            </div>
                            <span class="status-chip neutral">@Model.Cards.Count</span>
                        </div>

                        @if (Model.Cards.Any())
                        {
                            @for (int i = 0; i < Model.Cards.Count; i++)
                            {
                                var item = Model.Cards[i];

                                <div class="inner-card mb-3">
                                    <div><strong>Фрагмент:</strong> @item.Original</div>

                                    @if (!string.IsNullOrWhiteSpace(item.Correction))
                                    {
                                        <div><strong>Исправление:</strong> @item.Correction</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.Type))
                                    {
                                        <div><strong>Тип:</strong> @item.Type</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.Hint))
                                    {
                                        <div><strong>Комментарий:</strong> @item.Hint</div>
                                    }

                                    <div class="mt-3 d-flex flex-wrap gap-2">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary explain-btn"
                                                data-fragment="@item.Original"
                                                data-suggestion="@item.Correction"
                                                data-type="@item.Type"
                                                data-message="@item.Hint"
                                                data-sentence="@item.Sentence"
                                                data-target="accepted-explanation-@i">
                                            Пояснить
                                        </button>
                                    </div>

                                    <div id="accepted-explanation-@i" class="mt-3"></div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                Ошибок не найдено.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="app-card h-100">
                    <div class="app-card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3 flex-wrap">
                            <div>
                                <h3 class="section-card-title mb-1">Сомнительные случаи</h3>
                                <p class="section-card-text mb-0">Места, которые стоит проверить вручную дополнительно.</p>
                            </div>
                            <span class="status-chip warning">@Model.SuspiciousCards.Count</span>
                        </div>

                        @if (Model.SuspiciousCards.Any())
                        {
                            @for (int i = 0; i < Model.SuspiciousCards.Count; i++)
                            {
                                var item = Model.SuspiciousCards[i];

                                <div class="inner-card mb-3">
                                    <div><strong>Фрагмент:</strong> @item.Original</div>

                                    @if (!string.IsNullOrWhiteSpace(item.Correction))
                                    {
                                        <div><strong>Исправление:</strong> @item.Correction</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.Type))
                                    {
                                        <div><strong>Тип:</strong> @item.Type</div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(item.Hint))
                                    {
                                        <div><strong>Комментарий:</strong> @item.Hint</div>
                                    }

                                    <div class="section-state warning mt-2">Сомнительный случай</div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-state">
                                Сомнительных мест не найдено.
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="app-card">
            <div class="app-card-body">
                <div class="empty-state">
                    Результаты проверки появятся здесь после запуска анализа.
                </div>
            </div>
        </div>
    }
</div>

@await Html.PartialAsync("_LoadingOverlay", new RAGTEST.Models.LoadingOverlayViewModel
{
    OverlayId = "grammarLoadingOverlay",
    MessageId = "grammarLoadingMessage",
    Title = "Идёт проверка текста",
    InitialMessage = "Выполняется анализ орфографии и пунктуации...",
    Hint = "Это может занять некоторое время, так как используется локальная модель."
})

@section Scripts {
    <script>
        initLoadingForm({
            formId: "grammarForm",
            submitButtonId: "submitBtn",
            overlayId: "grammarLoadingOverlay",
            messageId: "grammarLoadingMessage",
            submitText: "Проверить",
            loadingButtonText: "Идёт анализ...",
            messages: [
                "Выполняется анализ орфографии и пунктуации...",
                "Проверяются возможные ошибки в тексте...",
                "Обрабатывается результат проверки...",
                "Формируется список найденных ошибок...",
                "Почти готово..."
            ]
        });

        document.addEventListener("DOMContentLoaded", function () {
            const buttons = document.querySelectorAll(".explain-btn");

            buttons.forEach(button => {
                button.addEventListener("click", async function () {
                    const targetId = this.dataset.target;
                    const target = document.getElementById(targetId);

                    if (!target) {
                        return;
                    }

                    this.disabled = true;
                    const originalText = this.textContent;
                    this.textContent = "Загрузка...";

                    target.innerHTML = `
                        <div class="summary-panel">
                            <div class="fw-semibold mb-2">Пояснение</div>
                            <div class="text-muted">Запрашиваем пояснение у модели...</div>
                        </div>
                    `;

                    try {
                        const response = await fetch("/PostCheck/ExplainGrammarItemProxy", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                                body: JSON.stringify({
                                fragment: this.dataset.fragment || "",
                                suggestion: this.dataset.suggestion || "",
                                type: this.dataset.type || "",
                                message: this.dataset.message || "",
                                sentence: this.dataset.sentence || ""
                            })
                        });

                        if (!response.ok) {
                            throw new Error("Ошибка запроса");
                        }

                        const data = await response.json();

                        target.innerHTML = `
                            <div class="summary-panel">
                                <div class="fw-semibold mb-2">Пояснение</div>
                                <div class="mb-2">${escapeHtml(data.explanation || "")}</div>
                                <div><strong>Совет:</strong> ${escapeHtml(data.hint || "")}</div>
                            </div>
                        `;
                    } catch (error) {
                        target.innerHTML = `
                            <div class="alert alert-danger mb-0">
                                Не удалось получить пояснение.
                            </div>
                        `;
                    } finally {
                        this.disabled = false;
                        this.textContent = originalText;
                    }
                });
            });

            function escapeHtml(text) {
                const div = document.createElement("div");
                div.textContent = text;
                return div.innerHTML;
            }
        });
    </script>
}