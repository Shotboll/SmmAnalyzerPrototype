@model StyleCheckPageModel

@{
    ViewData["Title"] = "Проверка стиля";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="fw-bold mb-2">Проверка стиля текста</h1>
        <p class="text-muted mb-0">Анализ выполняется для сохранённого поста.</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger shadow-sm border-0 rounded-4">
            @Model.ErrorMessage
        </div>
    }

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <h4 class="card-title mb-4">Параметры анализа</h4>

                    <div class="mb-3">
                        <div class="text-muted small">Сообщество</div>
                        <div class="fw-semibold">@Model.CommunityName</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small mb-2">Текст поста</div>
                        <div class="border rounded-4 p-3 bg-light" style="white-space: pre-wrap;">@Model.Text</div>
                    </div>

                    <form asp-action="Style" method="post" id="styleCheckForm">
                        @Html.AntiForgeryToken()
                        <input asp-for="PostId" type="hidden" />

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3" id="submitBtn">
                                Проверить стиль
                            </button>
                        </div>
                    </form>

                    <div class="mt-3">
                        <a asp-controller="Post" asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-outline-secondary">
                            Назад к посту
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h4 class="card-title mb-0">Результат анализа</h4>

                        @if (Model.Result != null)
                        {
                            var badgeClass = Model.Result.Assessment?.ToLower() switch
                            {
                                "соответствует" => "bg-success-subtle text-success",
                                "частично соответствует" => "bg-warning-subtle text-warning",
                                "не соответствует" => "bg-danger-subtle text-danger",
                                _ => "bg-secondary-subtle text-secondary"
                            };

                            <span class="badge rounded-pill px-3 py-2 @badgeClass">
                                @Model.Result.Assessment
                            </span>
                        }
                    </div>

                    @if (Model.Result != null)
                    {
                        <div class="mb-4">
                            <div class="p-3 bg-light rounded-4 border">
                                <div class="fw-semibold mb-2">Общий вывод</div>
                                <div>@Model.Result.Summary</div>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="border rounded-4 p-3 h-100 bg-white">
                                    <h5 class="mb-3">Сильные стороны</h5>
                                    @if (Model.Result.Strengths.Any())
                                    {
                                        <ul class="mb-0 ps-3">
                                            @foreach (var item in Model.Result.Strengths)
                                            {
                                                <li class="mb-2">@item</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">Сильные стороны не выделены.</p>
                                    }
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="border rounded-4 p-3 h-100 bg-white">
                                    <h5 class="mb-3">Что можно улучшить</h5>
                                    @if (Model.Result.Issues.Any())
                                    {
                                        <ul class="mb-0 ps-3">
                                            @foreach (var item in Model.Result.Issues)
                                            {
                                                <li class="mb-2">@item</li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">Явных проблем не найдено.</p>
                                    }
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="border rounded-4 p-3 bg-white">
                                    <h5 class="mb-3">Рекомендации</h5>
                                    @if (Model.Result.Recommendations.Any())
                                    {
                                        <ol class="mb-0 ps-3">
                                            @foreach (var item in Model.Result.Recommendations)
                                            {
                                                <li class="mb-2">@item</li>
                                            }
                                        </ol>
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">Рекомендации не были сформированы.</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center h-100">
                            <div class="text-center text-muted py-5">
                                <div class="fs-5 fw-semibold mb-2">Пока нет результата</div>
                                <div>Нажмите кнопку запуска анализа.</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_LoadingOverlay", new RAGTEST.Models.LoadingOverlayViewModel
{
    OverlayId = "styleLoadingOverlay",
    MessageId = "styleLoadingMessage",
    Title = "Идёт проверка стиля",
    InitialMessage = "Анализируем соответствие текста аудитории и стилю сообщества...",
    Hint = "Проверка может занять некоторое время, так как используется локальная модель."
})

@section Scripts {
    <script>
        initLoadingForm({
            formId: "styleCheckForm",
            submitButtonId: "submitBtn",
            overlayId: "styleLoadingOverlay",
            messageId: "styleLoadingMessage",
            submitText: "Проверить стиль",
            loadingButtonText: "Проверка...",
            messages: [
                "Анализируем соответствие текста аудитории и стилю сообщества...",
                "Извлекаем параметры выбранного сообщества...",
                "Оцениваем тон, лексику и подачу текста...",
                "Формируем сильные стороны и замечания...",
                "Подготавливаем рекомендации...",
                "Почти готово..."
            ]
        });
    </script>
}