@model RegulationCreateModel
@{
    ViewData["Title"] = "Добавить регламент";
}

<h2>Добавление нормативного документа</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">Название</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Категория</label>
        <input asp-for="Category" class="form-control" placeholder="Например: Контент-безопасность" />
        <span asp-validation-for="Category" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Текст регламента</label>
        <textarea asp-for="Content" class="form-control" rows="5" placeholder="Запрещено: политика, дискриминация..."></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Сообщество</label>
        <select asp-for="CommunityId" class="form-select" asp-items="ViewBag.Communities">
            <option value="">Выберите сообщество</option>
        </select>
        <span asp-validation-for="CommunityId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Добавить</button>
    <a asp-action="Index" class="btn btn-secondary">Отмена</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}